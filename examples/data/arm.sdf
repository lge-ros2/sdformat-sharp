<?xml version='1.0' ?>
<sdf version='1.12'>
  <model name='simple_arm'>
    <link name='base_link'>
      <inertial>
        <mass>5</mass>
        <inertia>
          <ixx>0.1</ixx><iyy>0.1</iyy><izz>0.1</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
      <collision name='collision'>
        <geometry>
          <cylinder>
            <radius>0.1</radius>
            <length>0.05</length>
          </cylinder>
        </geometry>
      </collision>
      <visual name='visual'>
        <geometry>
          <cylinder>
            <radius>0.1</radius>
            <length>0.05</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.5 0.5 0.5 1</ambient>
          <diffuse>0.5 0.5 0.5 1</diffuse>
        </material>
      </visual>
    </link>

    <link name='upper_arm'>
      <pose>0 0 0.5 0 0 0</pose>
      <inertial>
        <mass>2</mass>
      </inertial>
      <collision name='collision'>
        <geometry>
          <box>
            <size>0.05 0.05 1.0</size>
          </box>
        </geometry>
      </collision>
      <visual name='visual'>
        <geometry>
          <box>
            <size>0.05 0.05 1.0</size>
          </box>
        </geometry>
        <material>
          <ambient>0.8 0.2 0.2 1</ambient>
          <diffuse>0.8 0.2 0.2 1</diffuse>
        </material>
      </visual>
    </link>

    <link name='lower_arm'>
      <pose>0 0 1.5 0 0 0</pose>
      <inertial>
        <mass>1.5</mass>
      </inertial>
      <collision name='collision'>
        <geometry>
          <box>
            <size>0.04 0.04 0.8</size>
          </box>
        </geometry>
      </collision>
      <visual name='visual'>
        <geometry>
          <box>
            <size>0.04 0.04 0.8</size>
          </box>
        </geometry>
        <material>
          <ambient>0.2 0.8 0.2 1</ambient>
          <diffuse>0.2 0.8 0.2 1</diffuse>
        </material>
      </visual>
      <sensor name='force_torque' type='force_torque'>
        <update_rate>100</update_rate>
      </sensor>
    </link>

    <link name='gripper'>
      <pose>0 0 2.0 0 0 0</pose>
      <inertial>
        <mass>0.5</mass>
      </inertial>
      <collision name='collision'>
        <geometry>
          <box>
            <size>0.1 0.1 0.05</size>
          </box>
        </geometry>
      </collision>
      <visual name='visual'>
        <geometry>
          <box>
            <size>0.1 0.1 0.05</size>
          </box>
        </geometry>
        <material>
          <ambient>0.2 0.2 0.8 1</ambient>
          <diffuse>0.2 0.2 0.8 1</diffuse>
        </material>
      </visual>
    </link>

    <joint name='shoulder_joint' type='revolute'>
      <parent>base_link</parent>
      <child>upper_arm</child>
      <axis>
        <xyz>0 1 0</xyz>
        <limit>
          <lower>-1.57</lower>
          <upper>1.57</upper>
          <effort>100</effort>
          <velocity>1.0</velocity>
        </limit>
        <dynamics>
          <damping>0.5</damping>
          <friction>0.1</friction>
        </dynamics>
      </axis>
    </joint>

    <joint name='elbow_joint' type='revolute'>
      <parent>upper_arm</parent>
      <child>lower_arm</child>
      <axis>
        <xyz>0 1 0</xyz>
        <limit>
          <lower>-2.35</lower>
          <upper>0</upper>
          <effort>80</effort>
          <velocity>1.5</velocity>
        </limit>
        <dynamics>
          <damping>0.3</damping>
        </dynamics>
      </axis>
    </joint>

    <joint name='wrist_joint' type='revolute'>
      <parent>lower_arm</parent>
      <child>gripper</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-3.14</lower>
          <upper>3.14</upper>
          <effort>50</effort>
        </limit>
      </axis>
    </joint>

    <frame name='tool_frame' attached_to='gripper'>
      <pose>0 0 0.025 0 0 0</pose>
    </frame>

  </model>
</sdf>
